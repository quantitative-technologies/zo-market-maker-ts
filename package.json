{
  "name": "zo-market-maker",
  "version": "0.1.0",
  "description": "A simple market maker bot for 01 Exchange (Zo Protocol)",
  "type": "module",
  "main": "dist/cli/bot.js",
  "scripts": {
    "build": "tsc",
    "bot": "node --import tsx src/cli/bot.ts",
    "monitor": "node --import tsx src/cli/monitor.ts",
    "reserve-actions": "node --import tsx src/cli/reserve-actions.ts",
    "check": "biome check src",
    "format": "biome format --write src",
    "lint": "biome lint src",
    "test": "vitest run",
    "bench": "vitest bench",
    "bench:run": "vitest bench --run"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@n1xyz/nord-ts": "^0.3.5",
    "@solana/web3.js": "^1.98.0",
    "blessed": "^0.1.81",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.7",
    "lodash-es": "^4.17.23",
    "smol-toml": "^1.6.0",
    "tslog": "^4.10.2",
    "viem": "^2.47.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "@types/blessed": "^0.1.27",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=25.0.0"
  }
}
